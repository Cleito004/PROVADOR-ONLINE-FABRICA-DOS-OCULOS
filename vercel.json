{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.{glb,hdr,png,jpg,json,svg}",
      "use": "@vercel/static"
    },
    {
      "src": "core/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/(.*\\.(?:js|css|glb|hdr|png|jpg|json|svg|wasm))", "destination": "/$1" },
    { "source": "/core/(.*)", "destination": "/core/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
