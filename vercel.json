{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "core/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "core/assets/models/*.glb",
      "use": "@vercel/static",
      "headers": { "Content-Type": "model/gltf-binary" }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
